/* ===== VOICE ASSISTANT - DEDICATED PAGE ===== */
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
    --va-bg: #0A0E1A;
    --va-surface: #111827;
    --va-surface2: #1F2937;
    --va-border: #374151;
    --va-text: #F9FAFB;
    --va-muted: #9CA3AF;
    --va-blue: #3B82F6;
    --va-blue-glow: rgba(59, 130, 246, 0.3);
    --va-purple: #8B5CF6;
    --va-green: #10B981;
    --va-orange: #F59E0B;
    --va-red: #EF4444;
    --va-cyan: #06B6D4;
    --radius: 16px;
    --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}

html, body {
    height: 100%;
    overflow: hidden;
    font-family: var(--font);
    background: var(--va-bg);
    color: var(--va-text);
}

#bgCanvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
}

/* ===== TOP BAR ===== */
.va-topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    padding: 12px 24px;
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(55, 65, 81, 0.5);
}

.va-back {
    color: var(--va-muted);
    font-size: 18px;
    text-decoration: none;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px;
    transition: all 0.2s;
    margin-right: 16px;
}
.va-back:hover { background: var(--va-surface2); color: var(--va-text); }

.va-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
}

.va-logo {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--va-blue), var(--va-purple));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 16px; color: #fff;
}
.va-logo span { color: var(--va-cyan); }

.va-brand h1 { font-size: 16px; font-weight: 700; letter-spacing: -0.3px; }
.va-brand p { font-size: 11px; color: var(--va-muted); margin-top: 1px; }

.va-topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
}

.va-status {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--va-surface2);
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    color: var(--va-muted);
}

.va-status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--va-green);
    animation: dotPulse 2s ease-in-out infinite;
}

.va-status.listening .va-status-dot { background: var(--va-red); }
.va-status.thinking .va-status-dot { background: var(--va-orange); animation: dotPulse 0.5s ease-in-out infinite; }
.va-status.speaking .va-status-dot { background: var(--va-blue); }

@keyframes dotPulse {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
}

.va-lang-btn {
    background: linear-gradient(135deg, var(--va-purple), var(--va-blue));
    border: none;
    color: #fff;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--font);
    transition: all 0.2s;
}
.va-lang-btn:hover { transform: scale(1.05); box-shadow: 0 4px 15px var(--va-blue-glow); }

/* ===== MAIN LAYOUT ===== */
.va-main {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    height: 100vh;
    padding-top: 68px;
    gap: 0;
}

/* ===== CONVERSATION PANEL ===== */
.va-conversation {
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(55, 65, 81, 0.3);
    overflow: hidden;
}

.va-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px;
    scroll-behavior: smooth;
}

.va-messages::-webkit-scrollbar { width: 4px; }
.va-messages::-webkit-scrollbar-track { background: transparent; }
.va-messages::-webkit-scrollbar-thumb { background: var(--va-border); border-radius: 4px; }

/* Message Bubbles */
.va-msg {
    margin-bottom: 16px;
    animation: msgIn 0.35s ease;
    display: flex;
    flex-direction: column;
}

@keyframes msgIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
}

.va-msg-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
    padding-left: 2px;
}

.va-msg.user .va-msg-label { color: var(--va-blue); text-align: right; }
.va-msg.bot .va-msg-label { color: var(--va-purple); }

.va-msg-bubble {
    padding: 12px 16px;
    border-radius: 16px;
    font-size: 13.5px;
    line-height: 1.65;
    max-width: 95%;
    white-space: pre-line;
    position: relative;
}

.va-msg.user .va-msg-bubble {
    background: linear-gradient(135deg, var(--va-blue), #2563EB);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
}

.va-msg.bot .va-msg-bubble {
    background: var(--va-surface2);
    color: var(--va-text);
    border: 1px solid var(--va-border);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
}

.va-msg .msg-actions {
    display: flex;
    gap: 8px;
    margin-top: 6px;
    align-self: flex-start;
}

.va-msg .msg-action-btn {
    background: none;
    border: 1px solid var(--va-border);
    color: var(--va-muted);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 4px;
}
.va-msg .msg-action-btn:hover { border-color: var(--va-blue); color: var(--va-blue); }

/* Typing indicator */
.va-typing {
    display: flex;
    gap: 5px;
    padding: 14px 18px;
    background: var(--va-surface2);
    border: 1px solid var(--va-border);
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    width: fit-content;
}

.va-typing span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--va-muted);
    animation: typeBounce 1.2s ease-in-out infinite;
}
.va-typing span:nth-child(2) { animation-delay: 0.15s; }
.va-typing span:nth-child(3) { animation-delay: 0.3s; }

@keyframes typeBounce {
    0%,60%,100% { transform: translateY(0); }
    30% { transform: translateY(-8px); }
}

/* ===== CENTER - VOICE ORB ===== */
.va-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
    position: relative;
}

.va-orb-wrap {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
}

#waveCanvas {
    position: absolute;
    top: 0; left: 0;
    width: 320px; height: 320px;
    z-index: 1;
}

.va-orb {
    width: 120px; height: 120px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--va-surface2), var(--va-surface));
    border: 2px solid var(--va-border);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    z-index: 2;
    position: relative;
    transition: all 0.3s ease;
    box-shadow: 0 0 40px rgba(59, 130, 246, 0.1);
}

.va-orb i {
    font-size: 36px;
    color: var(--va-muted);
    transition: all 0.3s;
}

.va-orb:hover {
    border-color: var(--va-blue);
    box-shadow: 0 0 60px var(--va-blue-glow);
}
.va-orb:hover i { color: var(--va-blue); }

/* States */
.va-orb.listening {
    border-color: var(--va-red);
    box-shadow: 0 0 60px rgba(239, 68, 68, 0.3);
    animation: orbPulse 1.5s ease-in-out infinite;
}
.va-orb.listening i { color: var(--va-red); }

.va-orb.thinking {
    border-color: var(--va-orange);
    box-shadow: 0 0 60px rgba(245, 158, 11, 0.3);
}
.va-orb.thinking i { color: var(--va-orange); animation: spin 1.5s linear infinite; }

.va-orb.speaking {
    border-color: var(--va-blue);
    box-shadow: 0 0 80px var(--va-blue-glow);
}
.va-orb.speaking i { color: var(--va-blue); }

@keyframes orbPulse {
    0%,100% { transform: scale(1); }
    50% { transform: scale(1.04); }
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.va-orb-label {
    position: absolute;
    bottom: -8px;
    font-size: 12px;
    color: var(--va-muted);
    font-weight: 500;
    text-align: center;
    width: 100%;
    z-index: 2;
}

/* Text Input */
.va-text-input {
    display: flex;
    gap: 8px;
    width: 80%;
    max-width: 400px;
}

.va-text-input input {
    flex: 1;
    background: var(--va-surface2);
    border: 1px solid var(--va-border);
    color: var(--va-text);
    padding: 14px 20px;
    border-radius: 28px;
    font-size: 14px;
    font-family: var(--font);
    outline: none;
    transition: border-color 0.2s;
}
.va-text-input input:focus { border-color: var(--va-blue); }
.va-text-input input::placeholder { color: var(--va-muted); }

.va-text-input button {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--va-blue), var(--va-purple));
    border: none;
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
}
.va-text-input button:hover { transform: scale(1.08); box-shadow: 0 4px 20px var(--va-blue-glow); }

/* ===== INFO PANEL ===== */
.va-info-panel {
    border-left: 1px solid rgba(55, 65, 81, 0.3);
    overflow-y: auto;
    padding: 20px 16px;
}

.va-info-panel::-webkit-scrollbar { width: 4px; }
.va-info-panel::-webkit-scrollbar-thumb { background: var(--va-border); border-radius: 4px; }

.va-info-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    gap: 12px;
    color: var(--va-muted);
}
.va-info-placeholder i { font-size: 48px; opacity: 0.3; }
.va-info-placeholder h3 { font-size: 16px; font-weight: 600; opacity: 0.5; }
.va-info-placeholder p { font-size: 13px; opacity: 0.4; max-width: 200px; }

.va-info-cards {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

/* Info Card */
.va-card {
    background: var(--va-surface2);
    border: 1px solid var(--va-border);
    border-radius: var(--radius);
    padding: 16px;
    animation: cardIn 0.4s ease;
}

@keyframes cardIn {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
}

.va-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--va-border);
}

.va-card-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
}
.va-card-icon.bike { background: rgba(59,130,246,0.15); color: var(--va-blue); }
.va-card-icon.policy { background: rgba(16,185,129,0.15); color: var(--va-green); }
.va-card-icon.premium { background: rgba(245,158,11,0.15); color: var(--va-orange); }
.va-card-icon.quote { background: rgba(139,92,246,0.15); color: var(--va-purple); }

.va-card-title {
    font-size: 14px;
    font-weight: 700;
}

.va-card-subtitle {
    font-size: 11px;
    color: var(--va-muted);
    margin-top: 1px;
}

.va-card-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.va-card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12.5px;
}

.va-card-row .label { color: var(--va-muted); }
.va-card-row .value { font-weight: 600; color: var(--va-text); }
.va-card-row .value.highlight { color: var(--va-green); }
.va-card-row .value.premium { color: var(--va-orange); font-size: 15px; }

.va-card-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
}
.va-card-badge.petrol { background: rgba(239,68,68,0.15); color: #F87171; }
.va-card-badge.electric { background: rgba(16,185,129,0.15); color: #34D399; }
.va-card-badge.diesel { background: rgba(107,114,128,0.15); color: #9CA3AF; }

/* Quote cards */
.va-quote-card {
    background: var(--va-surface);
    border: 1px solid var(--va-border);
    border-radius: 12px;
    padding: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.2s;
    cursor: pointer;
}
.va-quote-card:hover { border-color: var(--va-blue); }

.va-quote-logo {
    width: 40px; height: 40px;
    background: var(--va-surface2);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 800;
    color: var(--va-blue);
}

.va-quote-info { flex: 1; }
.va-quote-name { font-size: 12px; font-weight: 600; }
.va-quote-claim { font-size: 10px; color: var(--va-green); margin-top: 2px; }
.va-quote-price { font-size: 16px; font-weight: 800; color: var(--va-orange); }

/* ===== SUGGESTIONS BAR ===== */
.va-suggestions {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 100;
    padding: 12px 24px;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    justify-content: center;
    background: rgba(10, 14, 26, 0.9);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(55, 65, 81, 0.3);
}

.va-suggestions::-webkit-scrollbar { display: none; }

.va-chip {
    background: var(--va-surface2);
    border: 1px solid var(--va-border);
    color: var(--va-text);
    padding: 8px 18px;
    border-radius: 24px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
    font-family: var(--font);
}
.va-chip:hover {
    border-color: var(--va-blue);
    background: rgba(59, 130, 246, 0.1);
    color: var(--va-blue);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
    .va-main {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr auto;
    }
    .va-conversation { display: none; }
    .va-info-panel {
        position: fixed;
        bottom: 60px; right: 0;
        width: 320px;
        max-height: 50vh;
        background: var(--va-bg);
        border: 1px solid var(--va-border);
        border-radius: 16px 0 0 0;
        z-index: 50;
        transform: translateX(100%);
        transition: transform 0.3s ease;
    }
    .va-info-panel.visible { transform: translateX(0); }
    .va-center { padding-bottom: 70px; }
}

@media (max-width: 640px) {
    .va-topbar { padding: 10px 16px; }
    .va-brand h1 { font-size: 14px; }
    .va-brand p { display: none; }
    .va-orb-wrap { width: 260px; height: 260px; }
    #waveCanvas { width: 260px; height: 260px; }
    .va-orb { width: 90px; height: 90px; }
    .va-orb i { font-size: 28px; }
    .va-text-input { width: 90%; }
    .va-info-panel { width: 100%; border-radius: 16px 16px 0 0; }
    .va-suggestions { padding: 10px 16px; }
}
